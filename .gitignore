# Local secrets and personal scratch notes
*tinyfish*api*.txt
*api key*.txt
*apikey*.txt
Local.txt
Rig Esterno.txt
# Diagnostics/export artifacts
*.gz
*.zip
devin-diagnostics.json.gz
# Runtime memory state: reproducible seeds live in scripts/seed_core_memory.py
# The live JSONL changes as the agents learn and may contain private context.
devin/memory/local_memories.jsonl
# Local-only archive for scratch notes/secrets moved out of root
archive/private_local/


