{
  "name": "devin-ai-ide-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "DEVIN AI IDE desktop wrapper for the local FastAPI workspace shell.",
  "type": "module",
  "scripts": {
    "desktop:dev": "node_modules\\\\.bin\\\\tauri.cmd dev",
    "desktop:build": "node_modules\\\\.bin\\\\tauri.cmd build",
    "backend": "python devin/ui/fast_app.py",
    "desktop:info": "node_modules\\\\.bin\\\\tauri.cmd info",
    "desktop:launch": "powershell -ExecutionPolicy Bypass -File ./scripts/devin-tauri-dev.ps1",
    "backend:headless": "powershell -ExecutionPolicy Bypass -File ./scripts/devin-tauri-dev.ps1 -SkipTauri",
    "desktop:preflight": "powershell -ExecutionPolicy Bypass -File ./scripts/check-tauri-env.ps1",
    "desktop:open": "powershell -ExecutionPolicy Bypass -File ./scripts/devin-tauri-dev.ps1 -BrowserFallback",
    "desktop:windows-host": "powershell -ExecutionPolicy Bypass -File ./scripts/launch-windows-desktop-host.ps1 -BrowserFallback",
    "desktop:prepare-host": "powershell -ExecutionPolicy Bypass -File ./scripts/prepare-windows-desktop-host.ps1",
    "desktop:windows-info": "powershell -ExecutionPolicy Bypass -File ./scripts/launch-windows-desktop-host.ps1 -Info -SkipNpmInstall"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2"
  }
}
