{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DEVIN AI IDE",
  "version": "0.1.0",
  "identifier": "local.devin.aiide",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "DEVIN AI IDE",
        "width": 1440,
        "height": 920,
        "minWidth": 1100,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"],
    "resources": {
      "../dist/devin-backend": "devin-backend"
    }
  }
}
